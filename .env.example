# Copy to .env and edit. .env is auto-loaded by docker compose.

# ── Which services start with plain "docker compose up -d" ──────────────────
# Comma-separated list of profiles. Without this you have to add --profile XXX
# to every command. Available: cookies, foryou
COMPOSE_PROFILES=cookies,foryou

# ── PYTR ───────────────────────────────────────────────────────────────────
TRUSTED_PROXY=

# ── For You sidecar ────────────────────────────────────────────────────────
# Backend: none | ollama | llamacpp | api
# Default is 'ollama' which talks to the bundled ollama container — no host
# install needed. Override to 'api' if you want a cloud provider instead.
FORYOU_LLM_BACKEND=ollama
FORYOU_EMBED_BACKEND=ollama

# Models pulled on first boot into the ollama-models docker volume.
FORYOU_OLLAMA_MODEL=gemma3:4b
FORYOU_OLLAMA_EMBED_MODEL=embeddinggemma

# Set to 0 to skip the first-boot model pull (useful if you populated the volume
# manually or want to manage models yourself).
FORYOU_OLLAMA_AUTOPULL=1

# Only used when FORYOU_LLM_BACKEND=api. Requires privacy_mode=cloud per-profile.
FORYOU_API_PROVIDER=gemini
FORYOU_API_KEY=
FORYOU_API_MODEL=
