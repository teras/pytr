# Copy to .env and edit. .env is auto-loaded by docker compose.

# ── Which services start with plain "docker compose up -d" ──────────────────
# Comma-separated list of profiles. Without this you have to add --profile XXX
# to every command. Available: cookies, foryou
COMPOSE_PROFILES=cookies,foryou

# ── PYTR ───────────────────────────────────────────────────────────────────
TRUSTED_PROXY=

# ── For You sidecar ────────────────────────────────────────────────────────
# Backend: none | openai | ollama | llamacpp | api
# Default 'openai' = a thin client against any OpenAI-compatible /v1 endpoint.
# Out of the box it points at the shared Ollama service (see Containers/ollama).
FORYOU_LLM_BACKEND=openai
FORYOU_EMBED_BACKEND=openai

# The OpenAI-compatible endpoint + model. Repoint at another local server or a
# remote provider by changing just these. API key is optional (empty for local).
FORYOU_LLM_BASE_URL=http://host.docker.internal:11434/v1
FORYOU_LLM_MODEL=gemma3:4b
FORYOU_EMBED_MODEL=embeddinggemma
FORYOU_LLM_API_KEY=

# Curated, privacy-gated cloud providers — only when FORYOU_LLM_BACKEND=api.
# Requires privacy_mode=cloud per-profile.
FORYOU_API_PROVIDER=gemini
FORYOU_API_KEY=
FORYOU_API_MODEL=
